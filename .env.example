# Cloudflare R2 credentials (S3-compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trellis-models
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Which TRELLIS model to use
# TRELLIS-text-base (342M), TRELLIS-text-large (1.1B), TRELLIS-text-xlarge (2.0B, default)
TRELLIS_MODEL=microsoft/TRELLIS-text-xlarge

# Optional: default GPU config for modal run
MODAL_GPU=A100
